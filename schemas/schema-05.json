{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer Motivation Database",
  "description": "Output schema for Step 05: Customer Motivation Database",
  "type": "object",
  "required": [
    "metadata",
    "pain_points",
    "desires",
    "fears",
    "frustrations",
    "behavioral_triggers",
    "confidence_scores"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "step",
        "agent",
        "timestamp",
        "brief_hash"
      ],
      "properties": {
        "step": {
          "type": "string",
          "enum": [
            "05"
          ]
        },
        "agent": {
          "type": "string",
          "enum": [
            "agent-05"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "brief_hash": {
          "type": "string"
        }
      }
    },
    "pain_points": {
      "type": "array",
      "minItems": 20,
      "items": {
        "type": "object",
        "required": [
          "pain",
          "severity",
          "frequency",
          "surface_or_deep"
        ],
        "properties": {
          "pain": {
            "type": "string"
          },
          "severity": {
            "type": "number",
            "minimum": 1,
            "maximum": 10
          },
          "frequency": {
            "type": "string",
            "enum": [
              "daily",
              "weekly",
              "monthly",
              "occasional"
            ]
          },
          "surface_or_deep": {
            "type": "string",
            "enum": [
              "surface",
              "deep"
            ]
          }
        }
      }
    },
    "desires": {
      "type": "array",
      "minItems": 20,
      "items": {
        "type": "object",
        "required": [
          "desire",
          "intensity",
          "type"
        ],
        "properties": {
          "desire": {
            "type": "string"
          },
          "intensity": {
            "type": "number",
            "minimum": 1,
            "maximum": 10
          },
          "type": {
            "type": "string",
            "enum": [
              "functional",
              "emotional",
              "social",
              "aspirational"
            ]
          }
        }
      }
    },
    "fears": {
      "type": "array",
      "minItems": 20,
      "items": {
        "type": "object",
        "required": [
          "fear",
          "impact",
          "type"
        ],
        "properties": {
          "fear": {
            "type": "string"
          },
          "impact": {
            "type": "number",
            "minimum": 1,
            "maximum": 10
          },
          "type": {
            "type": "string",
            "enum": [
              "financial",
              "social",
              "performance",
              "emotional",
              "physical"
            ]
          }
        }
      }
    },
    "frustrations": {
      "type": "array",
      "minItems": 20,
      "items": {
        "type": "object",
        "required": [
          "frustration",
          "root_cause",
          "current_workaround"
        ],
        "properties": {
          "frustration": {
            "type": "string"
          },
          "root_cause": {
            "type": "string"
          },
          "current_workaround": {
            "type": "string"
          }
        }
      }
    },
    "behavioral_triggers": {
      "type": "array",
      "minItems": 15,
      "items": {
        "type": "object",
        "required": [
          "trigger",
          "principle",
          "application"
        ],
        "properties": {
          "trigger": {
            "type": "string"
          },
          "principle": {
            "type": "string",
            "enum": [
              "scarcity",
              "urgency",
              "social_proof",
              "authority",
              "liking",
              "reciprocity",
              "commitment",
              "consistency",
              "loss_aversion",
              "anchoring",
              "framing"
            ]
          },
          "application": {
            "type": "string"
          }
        }
      }
    },
    "confidence_scores": {
      "type": "object",
      "required": [
        "overall",
        "pain_points",
        "desires",
        "fears",
        "frustrations",
        "behavioral_triggers"
      ],
      "properties": {
        "overall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "pain_points": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "desires": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fears": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "frustrations": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "behavioral_triggers": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}